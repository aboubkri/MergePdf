# Use a barebones Ubuntu image
FROM ubuntu:22.04

# Prevent interactive prompts during package installs
ENV DEBIAN_FRONTEND=noninteractive

# Install only the bare essentials needed to run the script (curl/sudo/bash)
RUN apt-get update && apt-get install -y \
    curl \
    sudo \
    bash \
    && rm -rf /var/lib/apt/lists/*

# Create a dummy user to test non-root installation
RUN useradd -m tester && echo "tester:tester" | chpasswd && adduser tester sudo
RUN echo 'tester ALL=(ALL) NOPASSWD:ALL' >> /etc/sudoers

USER tester
WORKDIR /home/tester/app

# Copy your project into the container
COPY --chown=tester:tester . .

# Grant execution rights
RUN chmod +x run.sh

# The script will fail at the very end because there is no "Display" 
# for the UI to pop up, but we can test the installation phase.
CMD ["./run.sh"]
